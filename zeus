}


def load_locations(path: str | Path | None = None):
    # Determine default path: locations.json next to this script (project root)
    if path is None:
        path = Path(__file__).resolve().parent / "locations.json"
    else:
        path = Path(path)

    try:
        if path.exists():
            with path.open("r", encoding="utf-8") as f:
                data = json.load(f)
            if isinstance(data, list):
                # Validate entries and keep only valid ones
                valid = []
                for entry in data:
                    if not isinstance(entry, dict):
                        continue
                    name = entry.get("name")
                    lat = entry.get("latitude")
                    lon = entry.get("longitude")
                    if (
                        isinstance(name, str)
                        and isinstance(lat, (int, float))
                        and isinstance(lon, (int, float))
                    ):
                        valid.append({"name": name, "latitude": float(lat), "longitude": float(lon)})
                if valid:
                    return valid
    except Exception:
        # Any error -> fall back to default
        pass

    # Fallback to default location list
    return [DEFAULT_LOCATION]


def get_default_location():
    locations = load_locations()
    return locations[0]


def fetch_weather(location: dict | None = None):
    if location is None:
        location = get_default_location()
    api_url = build_api_url(location["latitude"], location["longitude"])
    resp = requests.get(api_url, timeout=10)
    resp.raise_for_status()
    data = resp.json()
    current = data.get("current", {})
    daily = data.get("daily", {})
    return {
        "location": location.get("name", DEFAULT_LOCATION["name"]),
        "current": {
            "temp": current.get("temperature_2m"),
            "code": current.get("weather_code"),
        },
        "daily": [
            {
                "date": d,
                "tmax": tmax,
                "tmin": tmin,
                "code": code,
            }
            for d, tmax, tmin, code in zip(
                daily.get("time", []),
                daily.get("temperature_2m_max", []),
                daily.get("temperature_2m_min", []),
                daily.get("weather_code", []),
            )
        ],
        "fetched_at": datetime.now(),
    }


def code_to_desc_icon(code):
    if code in WEATHER_ICONS:
        return WEATHER_ICONS[code]
    return ("Unknown", "[?]")


def print_simple():
    data = fetch_weather()
    current = data["current"]
    daily = data["daily"]
    print("+" + "-" * 52 + "+")
    print(f"|Weather for {data['location']}")
    print("+" + "-" * 52 + "+")
    if current.get("temp") is not None:
        desc, icon = code_to_desc_icon(current.get("code"))
        print(f"|Now: {current['temp']:>5.1f}°C  {icon} {desc}")

    print("+" + "-" * 52 + "+")
    print("|Forecast:                                           |")
    print(f"|{'Date':<12}{'':<3}{'Description':<20}{'Temp':>5}            |")
    print("+" + "-" * 52 + "+")
    for d in daily:
        desc, icon = code_to_desc_icon(d.get("code"))

        print(
            f"|{d['date']:<12}"  # left aligned date
            f"{icon:<3}"  # icon column
            f"{desc:<20}"  # weather description
            f"{d['tmax']:>5.1f}°C / {d['tmin']:>5.1f}°C|"

        )
    print("+" + "-" * 52 + "+")

def main():
    try:
        locale.setlocale(locale.LC_ALL, "")
    except Exception:
        pass

    args = sys.argv[1:]

    if any(arg in ("--new", "-n") for arg in args):
        geolocator = Nominatim(user_agent="zeus-weather")
        location = geolocator.geocode(args[1])
        print(f"Latitude: {location.latitude}")
        print(f"Longitude: {location.longitude}")
        print(f"Full address: {location.address}")

    print_simple()

if __name__ == "__main__":
    main()